# Copia este archivo a una de estas rutas (no las subas al repo):
#   functions/.env
#   functions/.env.<TU_PROJECT_ID>   p. ej. .env.cuadre-caja-oficial
#
# Firebase CLI carga estas variables al desplegar Functions (Gen 2) y en el emulador.
# Ver: https://firebase.google.com/docs/functions/config-env

SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec
